---
import { loadGlobal } from "../lib/content";

const { name } = loadGlobal();
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container footer-inner">
    <p class="footer-desc">
      Still Our *-* Internet acts on the research and frameworks produced by
      <a href="https://interethos.org" target="_blank" rel="noopener noreferrer"
        >InterEthos.org</a
      ><br />
      Neither organization is subsidiary to the other.
    </p>
    <p class="footer-copy">
      &copy; {name}. Some rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--chalk);
    background-color: var(--linen);
    padding-block: 1.5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-desc {
    font-size: var(--text-sm);
    color: var(--ash);
    line-height: var(--leading-relaxed);
  }

  .footer-desc a {
    color: var(--ash);
    text-underline-offset: 0.2em;
    transition: color var(--transition-base);
  }

  .footer-desc a:hover {
    color: var(--timber);
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--ash);
    white-space: nowrap;
  }
</style>
