---
import { loadGlobal } from "../lib/content";

const { name } = loadGlobal();
---

<hr class="section-rule" />
<div class="footer-bottom">
  <p class="footer-desc">
    Still Our *-* Internet acts on the research and frameworks produced by
    <a href="https://interethos.org" target="_blank" rel="noopener noreferrer"
      >InterEthos.org</a
    >
    Neither organization is subsidiary to the other.
  </p>
  <p class="footer-copy">
    &copy; {name}. Some rights reserved.
  </p>
</div>

<style>
  .section-rule {
    height: 1px;
    border: none;
    background-color: var(--chalk);
  }

  .footer-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 15rem;
    padding-block: clamp(1.25rem, 2vw, 1.75rem);
  }

  .footer-desc {
    font-family: var(--font-sans);
    font-size: clamp(0.875rem, 1vw, 1.25rem);
    color: #3a362c;
    line-height: 1.3;
    letter-spacing: var(--tracking-normal);
  }

  .footer-desc a {
    color: #3a362c;
    text-underline-offset: 0.15em;
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: clamp(0.875rem, 1vw, 1.25rem);
    color: #3a362c;
    white-space: nowrap;
    line-height: 1.2;
    letter-spacing: var(--tracking-normal);
  }

  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
