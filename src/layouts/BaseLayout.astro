---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  /** Page-specific title. Omit on the home page to render just the site name. */
  title?: string;
  description?: string;
  ogImage?: string;
  /** Prevents indexing — use on 404, thank-you pages, etc. */
  noindex?: boolean;
  /**
   * JSON-LD structured data object. Serialised into a <script type="application/ld+json">.
   * Should be developer-supplied data only — never pass raw user input here.
   */
  jsonLD?: Record<string, unknown>;
  /** Strips header + footer — use on pages with fully custom chrome (e.g. coming-soon). */
  hideHeader?: boolean;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
  jsonLD,
  hideHeader = false,
} = Astro.props;

// Build the canonical URL. Requires `site` to be set in astro.config.mjs.
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      canonicalURL={canonicalURL}
    />

    <!-- JSON-LD structured data -->
    {jsonLD && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
    )}

    <!-- Client-side routing with animated page transitions (Astro 6) -->
    <ClientRouter />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Placeholder font — swap for final typeface when ready -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- Skip-to-content — first focusable element, visible on keyboard focus -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    {!hideHeader && <Header />}

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    {!hideHeader && <Footer />}

    <script>
      document.addEventListener("click", (e) => {
        if (window.matchMedia("(hover: hover)").matches) return;

        const target = e.target as HTMLElement;
        const tooltip = target.closest(".tooltip-soon")
          || target.querySelector(":scope > .tooltip-soon")
          || (target.parentElement?.querySelector(":scope > .tooltip-soon"));

        document.querySelectorAll(".tooltip-soon.is-visible").forEach((el) => {
          if (el !== tooltip) el.classList.remove("is-visible");
        });

        if (tooltip) {
          tooltip.classList.toggle("is-visible");
        }
      });
    </script>
  </body>
</html>
