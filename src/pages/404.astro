---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadPage } from "../lib/content";
import buttonArrow from "../assets/images/button-arrow.svg";
import dottedGrid from "../assets/images/dotted-grid.svg";

const { meta, options, content } = loadPage("404");
const c = content as {
  code: string;
  heading: string;
  message: string;
  cta: string;
  cta_href: string;
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  noindex={options?.noindex ?? false}
>
  <section class="error-page" style={`--dot-pattern: url(${dottedGrid.src})`}>
    <div class="error-content">
      <p class="error-code" aria-hidden="true">{c.code}</p>
      <h1>{c.heading}</h1>
      <p class="error-message">{c.message}</p>
      <a href={c.cta_href} class="button">
        {c.cta}
        <img src={buttonArrow.src} alt="" class="button-arrow" />
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(2rem, 3vw, 3rem);
    text-align: center;
    background: var(--parchment) var(--dot-pattern) repeat top left / 0.5%;
    border-radius: clamp(1.5rem, 3vw, 3.125rem);
    margin: clamp(1rem, 2vw, 2rem);
    min-height: 50vh;
  }

  .error-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .error-code {
    font-size: clamp(5rem, 16vw, 8rem);
    font-weight: 700;
    line-height: 1;
    margin: 5rem 0 -2rem;
    color: var(--timber);
    letter-spacing: -0.04em;
    -webkit-user-select: none;
    user-select: none;
  }

  .error-message {
    color: var(--ash);
    max-width: 40ch;
  }
</style>
