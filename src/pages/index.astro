---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadGlobal, loadPage } from "../lib/content";

import cardDarkIllus from "../assets/images/card-dark-illustration.svg";
import cardPhotoArch from "../assets/images/card-photo-arch.png";
import cardBgPhoto from "../assets/images/card-bg-photo.jpg";
import cardWireframe from "../assets/images/card-wireframe.svg";
import cardBgForeground from "../assets/images/card-bg-foreground.svg";
import buttonArrow from "../assets/images/button-arrow.svg";
import liminalTrain from "../assets/images/liminal-train.mp4";

const global = loadGlobal();
const { meta, content } = loadPage("home");

const c = content as {
  tagline: string;
  tabs: Array<{ id: string; label: string }>;
  panels: Array<{
    id: string;
    eyebrow: string;
    heading: string;
    body: string;
    cta_text: string;
    cta_href: string;
  }>;
  cards: Array<{
    id: string;
    style: string;
    image: string | null;
    tag: string | null;
    caption: string | null;
  }>;
  founding_heading: string;
  founding_body: string[];
};

const jsonLD = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: global.name,
  description: global.description,
  url: global.url,
};

const cardImages: Record<string, ImageMetadata | string> = {
  "card-dark-illus": cardDarkIllus,
  "card-photo-arch": cardPhotoArch,
  "card-bg-photo": cardBgPhoto,
  "card-wireframe": cardWireframe,
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
  hideHeader={true}
>
  <div class="home" x-data="homeTab">
    <div class="home-top">
      <a href="/" class="home-logo" aria-label="Still Our Internet — home">
        <img
          src="/logo.svg"
          alt="Still Our Internet"
          width="268"
          height="208"
        />
      </a>
      <nav class="home-nav" aria-label="Main navigation">
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/research">Research</a>
        <a href="/collaborate">Collaborate</a>
      </nav>
    </div>

    <div
      class="tab-bar"
      role="tablist"
      aria-label="Explore by audience"
      x-ref="tabBar"
      @mouseleave="resetLavalamp()"
    >
      {
        c.tabs.map((t) => (
          <button
            role="tab"
            class="button tab-button"
            x-bind:class={`tab === '${t.id}' ? 'is-active' : ''`}
            x-on:click={`selectTab('${t.id}', $el)`}
            x-bind:aria-selected={`tab === '${t.id}'`}
            aria-controls={`panel-${t.id}`}
            x-on:mouseenter={`moveLavalamp($el, '${t.id}')`}
            x-on:focus={`moveLavalamp($el, '${t.id}')`}
          >
            {t.label}
          </button>
        ))
      }
      <span
        class="tab-lavalamp"
        :class="{ 'is-ready': lavalampReady }"
        :style="`left: ${lavalampLeft}px; width: ${lavalampWidth}px; top: ${lavalampTop}px; height: ${lavalampHeight}px`"
        aria-hidden="true"></span>
    </div>

    <svg width="0" height="0" style="position:absolute">
      <defs>
        <clipPath id="double-arches" clipPathUnits="objectBoundingBox">
          <path d="M0,0 L1,0 C1,0.276 0.776,0.5 0.5,0.5 C0.224,0.5 0,0.276 0,0 Z M0,0.5 L1,0.5 C1,0.776 0.776,1 0.5,1 C0.224,1 0,0.776 0,0.5 Z" />
        </clipPath>
      </defs>
    </svg>

    <div class="home-main">
      <div class="cards-grid" aria-hidden="true">
        {
          c.cards.map((card) => {
            const imgSrc = card.image ? cardImages[card.image] : undefined;
            const src = imgSrc
              ? typeof imgSrc === "string"
                ? imgSrc
                : imgSrc.src
              : undefined;
            return (
              <div class={`card card-${card.style}`}>
                {card.style === "dark" && (
                  <Fragment>
                    {src && <img src={src} alt="" class="card-illus" />}
                    {card.caption && <p class="card-caption">{card.caption}</p>}
                  </Fragment>
                )}
                {card.style === "video" && (
                  <div class="card-arches">
                    {src && <img src={src} alt="" class="card-fill-img" />}
                    <video
                      class="card-fill-video"
                      autoplay
                      loop
                      muted
                      playsinline
                      src={liminalTrain}
                    />
                  </div>
                )}
                {card.style === "bg-photo" && (
                  <Fragment>
                    {src && <img src={src} alt="" class="card-bg-img" />}
                    <div class="card-overlay">
                      {card.tag && <span class="card-tag">{card.tag}</span>}
                      <img src={cardBgForeground.src} alt="" class="card-fg-img" />
                      {card.caption && <p class="card-title">{card.caption}</p>}
                    </div>
                  </Fragment>
                )}
                {card.style === "outline" && (
                  <Fragment>
                    {card.tag && <span class="card-tag">{card.tag}</span>}
                    {src && <img src={src} alt="" class="card-illus card-illus-mid" />}
                    {card.caption && <p class="card-title">{card.caption}</p>}
                  </Fragment>
                )}
              </div>
            );
          })
        }
      </div>

      <div class="tab-panels">
        {
          c.panels.map((panel) => (
            <div
              id={`panel-${panel.id}`}
              role="tabpanel"
              class="tab-panel"
              x-show={`tab === '${panel.id}'`}
              x-cloak
            >
              <p class="panel-eyebrow">{panel.eyebrow}</p>
              <h2 class="panel-heading">{panel.heading}</h2>
              <div class="panel-body">
                {panel.body.split("|").map((p) => (
                  <p>{p}</p>
                ))}
              </div>
              <a href={panel.cta_href} class="button panel-cta">
                {panel.cta_text}<img src={buttonArrow.src} alt="" class="button-arrow" />
              </a>
            </div>
          ))
        }
      </div>
    </div>

    <div class="section-rule" role="separator"></div>

    <div class="founding-section">
      <div class="founding-text">
        <h2 class="founding-heading">{c.founding_heading}</h2>
        <div class="founding-body">
          {c.founding_body.map((p) => <p>{p}</p>)}
        </div>
      </div>
      <nav class="founding-nav" aria-label="Site navigation">
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/research">Research</a>
        <a href="/collaborate">Collaborate</a>
      </nav>
    </div>

    <div class="section-rule" role="separator"></div>

    <footer class="home-footer" role="contentinfo">
      <p class="footer-desc">
        Still Our Internet acts on the research and frameworks produced by
        <a
          href="https://interethos.org"
          target="_blank"
          rel="noopener noreferrer">InterEthos</a
        >. Neither organization is subsidiary to the other.
      </p>
      <p class="footer-copy">All rights reserved</p>
    </footer>
  </div>
</BaseLayout>

<style>
  /* Page wrapper */

  .home {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100svh;
    padding-inline: clamp(1.25rem, 8.5vw, 9rem);
    background-color: var(--linen);
  }

  /* Top: logo + nav */

  .home-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding-block: clamp(1.75rem, 5vw, 4rem);
  }

  .home-logo {
    display: block;
    line-height: 0;
    flex-shrink: 0;
  }

  .home-logo img {
    width: clamp(140px, 18vw, 268px);
    height: auto;
  }

  .home-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: clamp(0.4rem, 0.8vw, 0.65rem);
  }

  .home-nav a,
  .founding-nav a {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.5rem);
    font-weight: 400;
    color: var(--timber);
    text-decoration: line-through;
    letter-spacing: var(--tracking-normal);
    pointer-events: none;
  }

  /* Tab bar */

  .tab-bar {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 92%;
    background-color: var(--parchment);
    border-radius: 100px;
    padding: clamp(6px, 0.65vw, 10px);
    gap: 2px;
    margin-block-end: clamp(1.5rem, 3vw, 3rem);
  }

  .tab-button {
    position: relative;
    z-index: 1;
    flex: 1;
    margin: 0;
    background: transparent;
    padding: 1rem 1.5rem 0.625rem;
    font-size: clamp(0.8rem, 1.25vw, 1.5625rem);
    font-weight: 400;
    letter-spacing: normal;
    color: var(--timber);
    white-space: nowrap;
  }

  .tab-button.is-active {
    background-color: var(--timber);
    color: var(--linen);
  }

  .tab-lavalamp {
    position: absolute;
    background-color: rgba(0, 0, 0, 0.08);
    border-radius: 100px;
    pointer-events: none;
  }

  .tab-lavalamp.is-ready {
    transition:
      left 300ms ease-out,
      width 300ms ease-out,
      top 300ms ease-out,
      height 300ms ease-out;
  }

  /* Main layout: cards + panels */

  .home-main {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: center;
    margin-block-end: clamp(2.5rem, 5vw, 5rem);
  }

  /* Cards grid */

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.75rem, 1.1vw, 1.125rem);
  }

  .card {
    border-radius: clamp(1.5rem, 4vw, 3.68rem);
    overflow: hidden;
    aspect-ratio: 381 / 362;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Card 1: dark + illustration */
  .card-dark {
    background-color: var(--timber);
    padding: clamp(0.875rem, 1.2vw, 1.25rem);
    justify-content: space-between;
  }

  .card-dark .card-illus {
    flex: 1;
    width: 83%;
    align-self: center;
    object-fit: contain;
    min-height: 0;
  }

  /* Card 2: full-bleed photo (arch/union shape) */
  .card-video {
    padding: 0;
    background: transparent;
    border-radius: 0;
    overflow: visible;
  }

  .card-arches {
    position: relative;
    width: 100%;
    height: 100%;
    clip-path: url(#double-arches);
  }

  .card-fill-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-fill-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Card 3: photo background with content overlay */
  .card-bg-photo {
    padding: 0;
    background-color: var(--chalk);
  }

  .card-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: clamp(0.875rem, 1.2vw, 1.25rem);
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--timber) 5%, transparent) 0%,
      transparent 40%,
      color-mix(in srgb, var(--timber) 45%, transparent) 100%
    );
  }

  .card-caption {
    font-family: var(--font-sans);
    font-size: clamp(0.75rem, 1.1vw, 1.375rem);
    font-weight: 400;
    color: var(--linen);
    line-height: var(--leading-tight);
    text-align: center;
    padding-block: clamp(0.5rem, 0.8vw, 0.875rem);
  }

  .card-tag {
    font-family: var(--font-din);
    font-size: clamp(0.625rem, 0.8vw, 0.875rem);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--timber) 70%, transparent);
    line-height: 1.8;
  }

  .card-bg-photo .card-tag {
    color: color-mix(in srgb, var(--linen) 85%, transparent);
  }

  .card-title {
    font-family: var(--font-sans);
    font-size: clamp(0.75rem, 1.1vw, 1.375rem);
    font-weight: 400;
    color: var(--timber);
    line-height: var(--leading-tight);
    text-align: center;
  }

  .card-overlay .card-title {
    color: var(--linen);
  }

  .card-fg-img {
    width: 50%;
    align-self: center;
    object-fit: contain;
  }

  /* Card 4: outlined + wireframe */
  .card-outline {
    border: 1.5px solid var(--chalk);
    background-color: var(--linen);
    padding: clamp(0.875rem, 1.2vw, 1.25rem);
    justify-content: space-between;
  }

  .card-illus-mid {
    flex: 1;
    width: 70%;
    align-self: center;
    object-fit: contain;
    min-height: 0;
  }

  /* Tab panels */

  .tab-panels {
    padding-block-start: clamp(0.25rem, 0.8vw, 0.75rem);
  }

  .tab-panel {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.5vw, 1.5rem);
  }

  .panel-eyebrow {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.5625rem);
    font-weight: 400;
    color: var(--timber);
    margin: 0;
    line-height: 1.2;
  }

  .panel-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.625rem, 2.8vw, 2.8125rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .panel-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .panel-body p {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.4;
    margin: 0;
  }

  /* Section rule */

  .section-rule {
    height: 1px;
    background-color: var(--chalk);
  }

  /* Founding Note */

  .founding-section {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
    padding-block: clamp(2rem, 4vw, 4rem);
  }

  .founding-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.375rem, 1.8vw, 1.875rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.2;
    margin: 0 0 clamp(0.875rem, 1.3vw, 1.5rem);
  }

  .founding-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .founding-body p {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    color: var(--timber);
    line-height: 1.4;
    margin: 0;
  }

  .founding-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: clamp(0.4rem, 0.8vw, 0.65rem);
    padding-block-start: 0.25rem;
  }

  /* Footer */

  .home-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding-block: clamp(1.25rem, 2vw, 1.75rem);
  }

  .footer-desc {
    font-family: var(--font-sans);
    font-size: clamp(0.875rem, 1vw, 1.25rem);
    color: var(--timber);
    line-height: 1.3;
    letter-spacing: var(--tracking-normal);
  }

  .footer-desc a {
    color: var(--timber);
    text-underline-offset: 0.15em;
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: clamp(0.875rem, 1.4vw, 1.5rem);
    color: var(--timber);
    white-space: nowrap;
    line-height: 1.2;
    letter-spacing: var(--tracking-normal);
  }

  /* Responsive */

  @media (max-width: 900px) {
    .home-main {
      grid-template-columns: 1fr;
    }

    .tab-panels {
      padding-block-start: 0;
    }
  }

  @media (max-width: 640px) {
    .tab-bar {
      flex-wrap: wrap;
      border-radius: 1.25rem;
      gap: 4px;
    }

    .tab-button {
      flex: none;
      height: 40px;
    }

    .tab-button.is-active {
      background-color: var(--timber);
    }

    .tab-lavalamp {
      display: none;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .card {
      aspect-ratio: auto;
      min-height: clamp(220px, 50vw, 320px);
    }

    .founding-section {
      grid-template-columns: 1fr;
    }

    .founding-nav {
      align-items: flex-start;
    }

    .home-top {
      flex-direction: column;
      gap: 1.5rem;
    }

    .home-nav {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 1.25rem;
    }

    .home-footer {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>

<script>
  document.addEventListener("alpine:init", () => {
    Alpine.data("homeTab", () => ({
      tab: "anyone",
      hoverTab: null,
      lavalampLeft: 0,
      lavalampWidth: 0,
      lavalampTop: 0,
      lavalampHeight: 0,
      lavalampReady: false,

      init() {
        this.$nextTick(() => {
          this.resetLavalamp();
          setTimeout(() => {
            this.lavalampReady = true;
          }, 50);
        });
      },

      moveLavalamp(el, id) {
        const bar = this.$refs.tabBar.getBoundingClientRect();
        const btn = el.getBoundingClientRect();
        this.lavalampLeft = btn.left - bar.left;
        this.lavalampWidth = btn.width;
        this.lavalampTop = btn.top - bar.top;
        this.lavalampHeight = btn.height;
        if (id) this.hoverTab = id;
      },

      resetLavalamp() {
        this.hoverTab = null;
        const active = this.$refs.tabBar.querySelector(
          "[aria-selected='true']",
        );
        if (active) {
          const bar = this.$refs.tabBar.getBoundingClientRect();
          const btn = active.getBoundingClientRect();
          this.lavalampLeft = btn.left - bar.left;
          this.lavalampWidth = btn.width;
          this.lavalampTop = btn.top - bar.top;
          this.lavalampHeight = btn.height;
        }
      },

      selectTab(id, el) {
        this.tab = id;
        this.$nextTick(() => this.moveLavalamp(el));
      },
    }));
  });
</script>
