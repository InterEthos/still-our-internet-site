---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadGlobal, loadPage } from "../lib/content";

const global = loadGlobal();
const { meta, content } = loadPage("home");
const c = content as { tagline: string };

const jsonLD = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: global.name,
  description: global.description,
  url: global.url,
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
  hideHeader={true}
>
  <div class="nav-container container">
    <nav class="home-nav" aria-label="Main navigation">
      <a href="/work">Work</a>
      <a href="/about">About</a>
      <a href="/research">Research</a>
      <a href="/collaborate">Collaborate</a>
    </nav>
  </div>

  <section class="work-in-progress">
    <div class="hero-card">
      <div class="hero-top">
        <h1 class="brand-name" aria-label="Still Our Internet">
          <img src="/logo.svg" alt="" aria-hidden="true" class="brand-svg" />
        </h1>
        <p class="status-label" aria-label="Is still under development">
          IS<br />
          STILL<br />
          UNDER<br />
          DEVELOPMENT<span class="cursor" aria-hidden="true">_</span>
        </p>
      </div>

      <!-- Lower content: globe + tagline, globe overflows below card -->
      <div class="hero-bottom">
        <!-- Placeholder: swap for final globe illustration asset -->
        <div
          class="globe-wrap"
          role="img"
          aria-label="Globe illustration — placeholder"
        >
          <div class="globe-gradient">
            <svg
              class="globe-wireframe"
              viewBox="0 0 100 100"
              fill="none"
              stroke="currentColor"
              stroke-width="1.2"
              aria-hidden="true"
            >
              <circle cx="50" cy="50" r="33"></circle>
              <ellipse cx="50" cy="50" rx="33" ry="10"></ellipse>
              <ellipse cx="50" cy="50" rx="33" ry="20"></ellipse>
              <ellipse cx="50" cy="50" rx="33" ry="29"></ellipse>
              <ellipse cx="50" cy="50" rx="13" ry="33"></ellipse>
              <ellipse cx="50" cy="50" rx="24" ry="33"></ellipse>
            </svg>
          </div>
        </div>

        <p class="tagline">{c.tagline}</p>
      </div>
    </div>
  </section>

  <!-- Footer lives outside the card, below the section -->
  <footer class="home-footer" role="contentinfo">
    <p class="footer-desc">
      Still Our *-* Internet acts on the research and frameworks produced by
      <a href="https://interethos.org" target="_blank" rel="noopener noreferrer"
        >InterEthos.org</a
      ><br />
      Neither organization is subsidiary to the other.
    </p>
    <p class="footer-copy">&copy; {global.name}. Some rights reserved.</p>
  </footer>
</BaseLayout>

<style>
  /* ---- Floating nav ---------------------------------------------------- */

  .nav-container {
    display: flex;
    justify-content: flex-end;
    padding-block: clamp(1rem, 2vw, 1.5rem);
  }

  .home-nav {
    /* position: fixed;
    top: clamp(1.5rem, 3vw, 2.5rem);
    right: clamp(1.5rem, 3vw, 2.5rem); */
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
    pointer-events: none;
    z-index: var(--z-header);
  }

  .home-nav a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ash);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    letter-spacing: 0.01em;
    transition: color var(--transition-fast);
    text-decoration: line-through !important;
  }

  .home-nav a:hover {
    color: var(--ash);
  }

  /* ---- Page wrapper ---------------------------------------------------- */

  .work-in-progress {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: stretch;
    /* Horizontal margins match PDF proportions (~8% each side) */
    padding-inline: clamp(1.5rem, 8vw, 8rem);
    /* Top: enough linen for the floating nav to breathe above the card */
    padding-top: clamp(4rem, 22vh, 10rem);
    padding-bottom: clamp(0.75rem, 2vh, 1.5rem);
  }

  /* ---- Hero card ------------------------------------------------------- */

  .hero-card {
    flex: 1;
    background-color: var(--parchment);
    border-radius: 1rem;
    /* Uniform card padding — top portion for space above brand name */
    padding: clamp(2.5rem, 5vw, 4.5rem);
    padding-top: clamp(3rem, 12vh, 7rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: visible;

    /* Subtle grid texture */
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--chalk) 55%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--chalk) 55%, transparent) 1px,
        transparent 1px
      );
    background-size: 36px 36px;
  }

  /* ---- Top: brand name + status side by side --------------------------- */

  .hero-top {
    display: flex;
    align-items: center;
    gap: clamp(3rem, 6vw, 6rem);
  }

  .brand-name {
    margin: 0;
    flex-shrink: 0;
    line-height: 0;
    color: var(--carbon);
  }

  .brand-svg {
    width: clamp(180px, 26vw, 380px);
    height: auto;
  }

  .status-label {
    font-size: clamp(0.75rem, 1.1vw, 1rem);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    line-height: var(--leading-snug);
    color: var(--carbon);
    text-transform: uppercase;
    margin: 0;
    white-space: nowrap;
  }

  .cursor {
    display: inline-block;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  /* ---- Bottom: globe + tagline ---------------------------------------- */

  .hero-bottom {
    display: flex;
    align-items: flex-end;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  /* Globe placeholder — overflows below the card boundary */
  .globe-wrap {
    flex-shrink: 0;
    width: clamp(200px, 24vw, 310px);
    aspect-ratio: 1 / 1;
    border-radius: 1.5rem;
    overflow: hidden;
    position: relative;
    bottom: clamp(-2.5rem, -5vw, -4rem); /* overflow below card */
  }

  .globe-gradient {
    width: 100%;
    height: 100%;
    background: radial-gradient(
      ellipse at 38% 38%,
      var(--sienna) 0%,
      var(--fuzzy-wuzzy) 38%,
      var(--lilac) 68%,
      var(--washed-blue) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16%;
  }

  .globe-wireframe {
    width: 100%;
    height: 100%;
    color: var(--carbon);
    opacity: 0.5;
  }

  /* Tagline */
  .tagline {
    font-size: clamp(1.25rem, 2.8vw, 2.5rem);
    font-weight: 400;
    line-height: var(--leading-snug);
    letter-spacing: -0.015em;
    color: var(--carbon);
    margin: 0;
    padding-bottom: clamp(1rem, 2vw, 2rem);
  }

  /* ---- Footer ---------------------------------------------------------- */

  .home-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding: clamp(1.25rem, 2vw, 1.75rem) clamp(0.75rem, 1.5vw, 1.5rem);
  }

  .footer-desc {
    font-size: var(--text-sm);
    color: var(--ash);
    line-height: var(--leading-relaxed);
  }

  .footer-desc a {
    color: var(--ash);
    text-underline-offset: 0.2em;
    transition: color var(--transition-fast);
  }

  .footer-desc a:hover {
    color: var(--carbon);
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--ash);
    white-space: nowrap;
  }

  /* ---- Responsive ------------------------------------------------------- */

  @media (max-width: 640px) {
    .home-nav {
      position: absolute;
    }

    .hero-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .hero-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .globe-wrap {
      bottom: 0;
    }
  }
</style>
