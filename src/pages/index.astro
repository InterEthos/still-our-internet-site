---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadGlobal, loadPage } from "../lib/content";

import globeSvg from "../assets/images/globe.svg";
import dottedGrid from "../assets/images/dotted-grid.png";
import stillOurInternet from "../assets/images/still-our-internet.svg";

const global = loadGlobal();
const { meta, content } = loadPage("home");

const c = content as {
  tagline: string;
  tabs: Array<{ id: string; label: string }>;
  panels: Array<{
    id: string;
    eyebrow: string;
    heading: string;
    body: string;
    cta_text: string;
    cta_href: string;
  }>;
  cards: Array<{
    id: string;
    style: string;
    image: string | null;
  }>;
  founding_heading: string;
  founding_body: string[];
};

const jsonLD = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: global.name,
  description: global.description,
  url: global.url,
};

const cardImages: Record<string, ImageMetadata | string> = {
  globe: globeSvg,
  "dotted-grid": dottedGrid,
  "still-our-internet": stillOurInternet,
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
  hideHeader={true}
>
  <div class="home" x-data="{ tab: 'anyone' }">

    <div class="home-top">
      <a href="/" class="home-logo" aria-label="Still Our Internet — home">
        <img src="/logo.svg" alt="Still Our Internet" width="268" height="208" />
      </a>
      <nav class="home-nav" aria-label="Main navigation">
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/research">Research</a>
        <a href="/collaborate">Collaborate</a>
      </nav>
    </div>

    <div class="tab-bar" role="tablist" aria-label="Explore by audience">
      {c.tabs.map(t => (
        <button
          role="tab"
          class="tab-btn"
          x-bind:class={`tab === '${t.id}' ? 'is-active' : ''`}
          x-on:click={`tab = '${t.id}'`}
          x-bind:aria-selected={`tab === '${t.id}'`}
          aria-controls={`panel-${t.id}`}
        >
          {t.label}
        </button>
      ))}
    </div>

    <div class="home-main">

      <div class="cards-grid" aria-hidden="true">
        {c.cards.map((card) => {
          const imgSrc = card.image ? cardImages[card.image] : undefined;
          const src = imgSrc ? (typeof imgSrc === "string" ? imgSrc : imgSrc.src) : undefined;
          return (
            <div class={`card card--${card.style}`}>
              {card.style === "dark" && src && (
                <img src={src} alt="" class="card-illus" />
              )}
              {card.style === "photo" && src && (
                <img src={src} alt="" class="card-fill-img" />
              )}
              {card.style === "bg-photo" && src && (
                <Fragment>
                  <img src={src} alt="" class="card-bg-img" />
                  <div class="card-overlay" />
                </Fragment>
              )}
              {card.style === "outline" && src && (
                <img src={src} alt="" class="card-illus card-illus--mid" />
              )}
            </div>
          );
        })}
      </div>

      <div class="tab-panels">
        {c.panels.map((panel) => (
          <div
            id={`panel-${panel.id}`}
            role="tabpanel"
            class="tab-panel"
            x-show={`tab === '${panel.id}'`}
            x-cloak
          >
            <p class="panel-eyebrow">{panel.eyebrow}</p>
            <h2 class="panel-heading">{panel.heading}</h2>
            <div class="panel-body">
              {panel.body.split("|").map((p) => <p>{p}</p>)}
            </div>
            <a href={panel.cta_href} class="panel-cta">{panel.cta_text}&thinsp;&#x2197;</a>
          </div>
        ))}
      </div>
    </div>

    <div class="section-rule" role="separator"></div>

    <div class="founding-section">
      <div class="founding-text">
        <h2 class="founding-heading">{c.founding_heading}</h2>
        <div class="founding-body">
          {c.founding_body.map((p) => <p>{p}</p>)}
        </div>
      </div>
      <nav class="founding-nav" aria-label="Site navigation">
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/research">Research</a>
        <a href="/collaborate">Collaborate</a>
      </nav>
    </div>

    <div class="section-rule" role="separator"></div>

    <footer class="home-footer" role="contentinfo">
      <p class="footer-desc">
        Still Our Internet acts on the research and frameworks produced by
        <a href="https://interethos.org" target="_blank" rel="noopener noreferrer">InterEthos</a>.
        Neither organization is subsidiary to the other.
      </p>
      <p class="footer-copy">All rights reserved</p>
    </footer>

  </div>
</BaseLayout>

<style>
  /* Page wrapper */

  .home {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100svh;
    padding-inline: clamp(1.25rem, 8.5vw, 9rem);
    background-color: var(--linen);
  }

  /* Top: logo + nav */

  .home-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding-block: clamp(1.75rem, 5vw, 4rem);
  }

  .home-logo {
    display: block;
    line-height: 0;
    flex-shrink: 0;
  }

  .home-logo img {
    width: clamp(140px, 18vw, 268px);
    height: auto;
  }

  .home-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: clamp(0.4rem, 0.8vw, 0.65rem);
  }

  .home-nav a,
  .founding-nav a {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.5rem);
    font-weight: 400;
    color: var(--carbon);
    text-decoration: line-through;
    letter-spacing: var(--tracking-normal);
    pointer-events: none;
  }

  /* Tab bar */

  .tab-bar {
    display: flex;
    align-items: center;
    background-color: var(--parchment);
    border-radius: 100px;
    padding: clamp(6px, 0.65vw, 10px);
    gap: 2px;
    margin-block-end: clamp(1.5rem, 3vw, 3rem);
  }

  .tab-btn {
    flex: 1;
    height: clamp(42px, 4.5vw, 65px);
    border: none;
    border-radius: 100px;
    background: transparent;
    padding: 0 clamp(0.5rem, 1.4vw, 1.5rem);
    font-family: var(--font-sans);
    font-size: clamp(0.8rem, 1.25vw, 1.5625rem);
    font-weight: 400;
    color: var(--carbon);
    cursor: pointer;
    white-space: nowrap;
    line-height: 1;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .tab-btn.is-active {
    background-color: var(--carbon);
    color: var(--linen);
  }

  .tab-btn:not(.is-active):hover {
    background-color: color-mix(in srgb, var(--chalk) 50%, transparent);
  }

  /* Main layout: cards + panels */

  .home-main {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(1.5rem, 3vw, 3.5rem);
    align-items: start;
    margin-block-end: clamp(2.5rem, 5vw, 5rem);
  }

  /* Cards grid */

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.75rem, 1.1vw, 1.125rem);
  }

  .card {
    border-radius: clamp(1.5rem, 4vw, 3.68rem);
    overflow: hidden;
    aspect-ratio: 381 / 362;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Card 1: dark + illustration */
  .card--dark {
    background-color: var(--carbon);
    padding: clamp(0.875rem, 1.2vw, 1.25rem);
    justify-content: space-between;
  }

  .card--dark .card-illus {
    flex: 1;
    width: 83%;
    align-self: center;
    object-fit: contain;
    min-height: 0;
  }


  /* Card 2: full-bleed photo (arch/union shape) */
  .card--photo {
    padding: 0;
    background-color: var(--chalk);
  }

  .card-fill-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Card 3: photo background with content overlay */
  .card--bg-photo {
    padding: 0;
    background-color: var(--chalk);
  }

  .card-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: clamp(0.875rem, 1.2vw, 1.25rem);
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--carbon) 5%, transparent) 0%,
      transparent 40%,
      color-mix(in srgb, var(--carbon) 45%, transparent) 100%
    );
  }

  /* Card 4: outlined + wireframe */
  .card--outline {
    border: 1.5px solid var(--chalk);
    background-color: var(--linen);
    padding: clamp(0.875rem, 1.2vw, 1.25rem);
    justify-content: space-between;
  }

  .card-illus--mid {
    flex: 1;
    width: 70%;
    align-self: center;
    object-fit: contain;
    min-height: 0;
  }

  /* Tab panels */

  .tab-panels {
    padding-block-start: clamp(0.25rem, 0.8vw, 0.75rem);
  }

  .tab-panel {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.5vw, 1.5rem);
  }

  .panel-eyebrow {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.5625rem);
    font-weight: 400;
    color: var(--carbon);
    margin: 0;
    line-height: 1.2;
  }

  .panel-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.625rem, 2.8vw, 2.8125rem);
    font-weight: 400;
    color: var(--carbon);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .panel-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .panel-body p {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    font-weight: 400;
    color: var(--carbon);
    line-height: 1.4;
    margin: 0;
  }

  .panel-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    background-color: var(--carbon);
    color: var(--linen);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.5625rem);
    font-weight: 400;
    padding: 0 clamp(1.25rem, 2vw, 2rem);
    height: clamp(44px, 4.3vw, 65px);
    border-radius: 100px;
    line-height: 1;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .panel-cta:hover {
    background-color: var(--ash);
    color: var(--linen);
  }

  /* Section rule */

  .section-rule {
    height: 1px;
    background-color: var(--chalk);
  }

  /* Founding Note */

  .founding-section {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
    padding-block: clamp(2rem, 4vw, 4rem);
  }

  .founding-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.375rem, 1.8vw, 1.875rem);
    font-weight: 400;
    color: var(--carbon);
    line-height: 1.2;
    margin: 0 0 clamp(0.875rem, 1.3vw, 1.5rem);
  }

  .founding-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .founding-body p {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    color: var(--carbon);
    line-height: 1.4;
    margin: 0;
  }

  .founding-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: clamp(0.4rem, 0.8vw, 0.65rem);
    padding-block-start: 0.25rem;
  }

  /* Footer */

  .home-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding-block: clamp(1.25rem, 2vw, 1.75rem);
  }

  .footer-desc {
    font-family: var(--font-sans);
    font-size: clamp(0.875rem, 1vw, 1.25rem);
    color: var(--carbon);
    line-height: 1.3;
    letter-spacing: var(--tracking-normal);
  }

  .footer-desc a {
    color: var(--carbon);
    text-underline-offset: 0.15em;
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: clamp(0.875rem, 1.4vw, 1.5rem);
    color: var(--carbon);
    white-space: nowrap;
    line-height: 1.2;
    letter-spacing: var(--tracking-normal);
  }

  /* Responsive */

  @media (max-width: 900px) {
    .home-main {
      grid-template-columns: 1fr;
    }

    .tab-panels {
      padding-block-start: 0;
    }
  }

  @media (max-width: 640px) {
    .tab-bar {
      flex-wrap: wrap;
      border-radius: 1.25rem;
      gap: 4px;
    }

    .tab-btn {
      flex: none;
      height: 40px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .card {
      aspect-ratio: auto;
      min-height: clamp(220px, 50vw, 320px);
    }

    .founding-section {
      grid-template-columns: 1fr;
    }

    .founding-nav {
      align-items: flex-start;
    }

    .home-top {
      flex-direction: column;
      gap: 1.5rem;
    }

    .home-nav {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 1.25rem;
    }

    .home-footer {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
