---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import { loadGlobal, loadPage } from "../lib/content";

import cardDarkIllus from "../assets/images/card-dark-illustration.svg";
import liminalTrainFallback from "../assets/images/liminal-train-fallback.png";
import blurredDawnGradient from "../assets/images/blurred-dawn-gradient.jpg";
import cardWireframe from "../assets/images/card-wireframe.svg";
import cardGlobe from "../assets/images/globe.svg";
import cardUndoneLabs from "../assets/images/undone-labs.svg";
import dottedGrid from "../assets/images/dotted-grid.svg";
import arrowLink from "../assets/images/arrow-link.svg";
import buttonArrow from "../assets/images/button-arrow.svg";
import liminalTrain from "../assets/images/liminal-train.mp4";

const global = loadGlobal();
const { meta, content } = loadPage("home");

const c = content as {
  tagline: string;
  tabs: Array<{ id: string; label: string }>;
  panels: Array<{
    id: string;
    eyebrow: string;
    heading: string;
    body: string;
    cta_text: string;
    cta_href: string;
  }>;
  cards: Array<{
    id: string;
    style: string;
    image: string | null;
    tag: string | null;
    caption: string | null;
    href: string | null;
  }>;
  upnext_heading: string;
  upnext_title: string;
  upnext_body: string[];
  upnext_cta: string;
  upnext_quote: string;
  founding_heading: string;
  founding_body: string[];
};

const jsonLD = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: global.name,
  description: global.description,
  url: global.url,
};

const cardImages: Record<string, ImageMetadata | string> = {
  "card-dark-illus": cardDarkIllus,
  "liminal-train-fallback": liminalTrainFallback,
  "blurred-dawn-gradient": blurredDawnGradient,
  "card-wireframe": cardWireframe,
  "card-globe": cardGlobe,
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
  hideHeader={true}
>
  <div class="home" x-data="homeTab">
    <header class="home-top">
      <a href="/" class="home-logo" aria-label="Still Our Internet — home">
        <img
          src="/logo.svg"
          alt="Still Our Internet"
          width="268"
          height="208"
        />
      </a>
      <nav class="home-nav" aria-label="Main navigation">
        <a href="/work" onclick="event.preventDefault()">Work<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
        <a href="/about" onclick="event.preventDefault()">About<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
        <a href="/research" onclick="event.preventDefault()">Research<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
        <a href="/collaborate" onclick="event.preventDefault()">Collaborate<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
      </nav>
    </header>

    <main>

    <nav
      class="tab-bar"
      role="tablist"
      aria-label="Explore by audience"
      x-ref="tabBar"
      @mouseleave="resetLavalamp()"
    >
      {
        c.tabs.map((t) => (
          <button
            role="tab"
            class="button tab-button"
            x-bind:class={`tab === '${t.id}' ? 'is-active' : ''`}
            x-on:click={`selectTab('${t.id}', $el)`}
            x-bind:aria-selected={`tab === '${t.id}'`}
            aria-controls={`panel-${t.id}`}
            x-on:mouseenter={`moveLavalamp($el, '${t.id}')`}
            x-on:focus={`moveLavalamp($el, '${t.id}')`}
          >
            {t.label}
          </button>
        ))
      }
      <span
        class="lavalamp-pill-current"
        :class="{ 'is-ready': lavalampReady }"
        :style="`left: ${activeLeft}px; width: ${activeWidth}px; top: ${activeTop}px; height: ${activeHeight}px`"
        aria-hidden="true"></span>
      <span
        class="lavalamp-pill"
        :class="{ 'is-ready': lavalampReady }"
        :style="`left: ${lavalampLeft}px; width: ${lavalampWidth}px; top: ${lavalampTop}px; height: ${lavalampHeight}px`"
        aria-hidden="true"></span>
    </nav>

    <svg width="0" height="0" style="position:absolute">
      <defs>
        <clipPath id="double-arches" clipPathUnits="objectBoundingBox">
          <path
            d="M0,0 L1,0 C1,0.276 0.776,0.5 0.5,0.5 C0.224,0.5 0,0.276 0,0 Z M0,0.5 L1,0.5 C1,0.776 0.776,1 0.5,1 C0.224,1 0,0.776 0,0.5 Z"
          ></path>
        </clipPath>
      </defs>
    </svg>

    <section class="home-main">
      <div class="cards-grid" aria-hidden="true">
        {
          c.cards.map((card) => {
            const imgSrc = card.image ? cardImages[card.image] : undefined;
            const src = imgSrc
              ? typeof imgSrc === "string"
                ? imgSrc
                : imgSrc.src
              : undefined;
            const Tag = card.href ? "a" : "div";
            return (
              <Tag class={`card card-${card.style}`} href={card.href || undefined} target={card.href ? "_blank" : undefined} rel={card.href ? "noopener noreferrer" : undefined}>
                {card.style === "dark" && (
                  <Fragment>
                    {src && <img src={src} alt="" class="card-illus" />}
                    {card.caption && <p class="card-caption">{card.caption}</p>}
                  </Fragment>
                )}
                {card.style === "video" && (
                  <div class="card-arches">
                    {src && <img src={src} alt="" class="card-fill-img" />}
                    <video
                      class="card-fill-video"
                      autoplay
                      loop
                      muted
                      playsinline
                      src={liminalTrain}
                    />
                  </div>
                )}
                {card.style === "bg-photo" && (
                  <Fragment>
                    {src && (
                      <div
                        class="dawn-gradient"
                        style={`background-image: url(${src})`}
                      />
                    )}
                    {card.href && <img src={arrowLink.src} alt="" class="card-arrow" />}
                    <div class="card-overlay">
                      {card.tag && <span class="card-tag">{card.tag}</span>}
                      <img
                        src={cardUndoneLabs.src}
                        alt=""
                        class="card-fg-img"
                      />
                      {card.caption && <p class="card-title">{card.caption}</p>}
                    </div>
                  </Fragment>
                )}
                {card.style === "outline" && (
                  <Fragment>
                    {card.tag && <span class="card-tag">{card.tag}</span>}
                    {src && (
                      <img src={src} alt="" class="card-illus card-illus-mid" />
                    )}
                    {card.caption && <p class="card-title">{card.caption}</p>}
                    <span class="tooltip-soon">coming soon<span class="tooltip-cursor">_</span></span>
                  </Fragment>
                )}
              </Tag>
            );
          })
        }
      </div>

      <div
        class="tab-panels"
        x-ref="tabPanels"
        :style="`height: ${panelHeight}px`"
      >
        {
          c.panels.map((panel) => (
            <div
              id={`panel-${panel.id}`}
              role="tabpanel"
              class="tab-panel"
              x-show={`tab === '${panel.id}'`}
              x-cloak
            >
              <p class="panel-eyebrow">{panel.eyebrow}</p>
              <h2 class="panel-heading">{panel.heading}</h2>
              <div class="panel-body">
                {panel.body.split("|").map((p) => (
                  <p>{p}</p>
                ))}
              </div>
              <a href={panel.cta_href} class="button panel-cta" onclick="event.preventDefault()">
                {panel.cta_text}
                <img src={buttonArrow.src} alt="" class="button-arrow" />
                <span class="tooltip-soon tooltip-right">coming soon<span class="tooltip-cursor">_</span></span>
              </a>
            </div>
          ))
        }
      </div>
    </section>

    <section
      class="upnext-card"
      style={`--dot-pattern: url(${dottedGrid.src})`}
    >
      <div class="upnext-left">
        <h2 class="upnext-heading">{c.upnext_heading}</h2>
        <p class="upnext-quote">{c.upnext_quote}</p>
      </div>
      <div class="upnext-right">
        <div class="upnext-title-row">
          <h3 class="upnext-title">{c.upnext_title}</h3>
          <span class="upnext-arrow-wrap">
            <img src={arrowLink.src} alt="" class="upnext-arrow" />
            <span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span>
          </span>
        </div>
        <div class="upnext-body">
          {c.upnext_body.map((p) => <p>{p}</p>)}
        </div>
        <p class="upnext-cta"><em>{c.upnext_cta}</em></p>
      </div>
    </section>

    </main>

    <footer class="site-footer" role="contentinfo">
      <hr class="section-rule" />

      <section class="superfooter">
        <div class="superfooter-text">
          <h2 class="superfooter-heading">{c.founding_heading}</h2>
          <div class="superfooter-body">
            {c.founding_body.map((p) => <p>{p}</p>)}
          </div>
        </div>
        <nav class="footer-nav" aria-label="Site navigation">
          <a href="/work" onclick="event.preventDefault()">Work<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
          <a href="/about" onclick="event.preventDefault()">About<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
          <a href="/research" onclick="event.preventDefault()">Research<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
          <a href="/collaborate" onclick="event.preventDefault()">Collaborate<span class="tooltip-soon tooltip-left">coming soon<span class="tooltip-cursor">_</span></span></a>
        </nav>
      </section>

      <hr class="section-rule" />

      <Footer />
    </footer>
  </div>
</BaseLayout>

<style>
  /* Page wrapper */

  .home {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100svh;
    padding-inline: clamp(1.25rem, 8.5vw, 9rem);
    background-color: var(--linen);
  }

  /* Top: logo + nav */

  .home-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding-block: clamp(1.75rem, 5vw, 4rem);
  }

  .home-logo {
    display: block;
    line-height: 0;
    flex-shrink: 0;
  }

  .home-logo img {
    width: clamp(140px, 18vw, 268px);
    height: auto;
  }

  .home-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: clamp(0.4rem, 0.8vw, 0.65rem);
  }

  .home-nav a,
  .footer-nav a {
    position: relative;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.5rem);
    font-weight: 400;
    color: var(--timber);
    text-decoration: none;
    letter-spacing: var(--tracking-normal);
  }

  .home-nav a::after,
  .footer-nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 40%;
    height: 1.5px;
    background-color: var(--timber);
  }

  /* Tab bar */

  .tab-bar {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 92%;
    background-color: var(--parchment);
    border-radius: 100px;
    padding: clamp(6px, 0.65vw, 10px);
    gap: 2px;
    margin-block-end: clamp(1.5rem, 3vw, 3rem);
  }

  .tab-button {
    position: relative;
    z-index: 1;
    flex: 1;
    margin: 0;
    background: transparent;
    padding: 1rem 1.5rem 0.625rem;
    font-size: clamp(0.8rem, 1.25vw, 1.5625rem);
    font-weight: 400;
    letter-spacing: normal;
    color: var(--timber);
    white-space: nowrap;
    transition: color 200ms ease 100ms;
  }

  .tab-button.is-active {
    color: var(--linen);
  }

  .lavalamp-pill-current {
    position: absolute;
    background-color: var(--timber);
    border-radius: 100px;
    pointer-events: none;
  }

  .lavalamp-pill-current.is-ready {
    transition:
      left 350ms ease-out,
      width 350ms ease-out,
      top 350ms ease-out,
      height 350ms ease-out;
  }

  .lavalamp-pill {
    position: absolute;
    background-color: rgba(0, 0, 0, 0.08);
    border-radius: 100px;
    pointer-events: none;
  }

  .lavalamp-pill.is-ready {
    transition:
      left 300ms ease-out,
      width 300ms ease-out,
      top 300ms ease-out,
      height 300ms ease-out;
  }

  /* Main layout: cards + panels */

  .home-main {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 7vw, 8rem);
    align-items: center;
    margin-block-end: clamp(2.5rem, 5vw, 5rem);
  }

  /* Cards grid */

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    row-gap: clamp(0.125rem, 0.3vw, 0.3rem);
    column-gap: clamp(0.75rem, 1.1vw, 1.125rem);
  }

  .card {
    border-radius: 2rem;
    overflow: hidden;
    aspect-ratio: 381 / 362;
    margin-bottom: 0.325rem;
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  /* Card 1: abstract line graph */
  .card-dark {
    background-color: var(--timber);
    padding: 5% 6%;
    justify-content: space-between;
  }

  .card-dark .card-illus {
    width: 83%;
    height: auto;
    margin: auto 0;
    align-self: center;
  }

  /* Card 2: double-arch video */
  .card-video {
    padding: 0;
    background: transparent;
    border-radius: 0;
    border: 0;
    padding: 0.5rem;
    margin-top: 0.25rem;
    overflow: visible;
  }

  .card-arches {
    position: relative;
    width: 100%;
    height: 100%;
    clip-path: url(#double-arches);
  }

  .card-fill-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-fill-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Card 3: undone labs dawn gradient */
  .blurred-dawn-gradient {
    padding: 0;
    background-color: var(--chalk);
  }

  .dawn-gradient {
    position: absolute;
    inset: 0;
    background-size: 130% auto;
    background-position: 30% 60%;
    background-repeat: no-repeat;
  }

  .card-overlay {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1 1 0;
    min-height: 0;
    padding: 5% 6%;
  }

  .card-caption {
    padding: 0 2rem;
    font-family: var(--font-sans);
    font-size: clamp(0.75rem, 1.1vw, 1.375rem);
    font-weight: 400;
    color: var(--linen);
    line-height: var(--leading-tight);
    text-align: center;
  }

  .card-arrow {
    position: absolute;
    top: 8%;
    right: 10%;
    width: clamp(0.65rem, 0.9vw, 0.85rem);
    height: auto;
    z-index: 2;
    transition: transform 250ms ease-out;
  }

  .card:hover .card-arrow {
    transform: rotate(45deg);
  }

  .card-tag {
    font-family: var(--font-din);
    font-size: clamp(0.625rem, 0.8vw, 0.875rem);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    margin: 0.325rem 0 0 1.25rem;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--timber) 70%, transparent);
    line-height: 1.8;
  }

  .blurred-dawn-gradient .card-tag {
    color: color-mix(in srgb, var(--linen) 85%, transparent);
  }

  .card-title {
    font-family: var(--font-sans);
    font-size: clamp(0.75rem, 1.1vw, 1.375rem);
    font-weight: 400;
    text-align: center;
    color: var(--timber);
    line-height: var(--leading-tight);
    margin-top: 3%;
  }

  .card-overlay .card-title {
    color: var(--timber);
  }

  .card-fg-img {
    width: 45%;
    height: auto;
    margin: auto 0;
    align-self: center;
  }

  /* Card 4: distorted wireframe */
  .card-outline {
    border: 1.5px solid var(--chalk);
    background-color: var(--linen);
    padding: 5% 6%;
    overflow: visible;
  }

  .card-illus-mid {
    width: 48%;
    height: auto;
    margin: auto 0;
    align-self: center;
  }

  /* Tab panels */

  .tab-panels {
    position: relative;
    overflow-x: visible;
    overflow-y: clip;
    padding-block-start: clamp(0.25rem, 0.8vw, 0.75rem);
    transition: height 350ms ease;
  }

  .tab-panel {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.5vw, 1.5rem);
  }

  .panel-eyebrow {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.5625rem);
    font-weight: 400;
    color: var(--timber);
    margin: 0;
    line-height: 1.2;
  }

  .panel-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.625rem, 2.8vw, 2.8125rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .panel-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .panel-body p {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.4;
    margin: 0;
  }

  .panel-cta {
    align-self: flex-start;
    margin-left: 0.5rem;
  }

  /* Up next */

  .upnext-card {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(3rem, 8vw, 10rem);
    background: var(--parchment) var(--dot-pattern) repeat top left / 0.5%;
    border-radius: clamp(1.5rem, 3vw, 3.125rem);
    padding: clamp(2rem, 3vw, 3rem);
    margin-block-end: clamp(2rem, 4vw, 4rem);
  }

  .upnext-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.375rem, 1.8vw, 1.875rem);
    font-weight: 400;
    color: var(--timber);
    line-height: var(--leading-tight);
    margin: 0 0 clamp(1.5rem, 3vw, 3rem);
  }

  .upnext-left {
    display: flex;
    flex-direction: column;
  }

  .upnext-quote {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.5rem);
    font-weight: 400;
    color: var(--timber);
    line-height: var(--leading-tight);
    margin: auto 0 0;
  }

  .upnext-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-block-end: clamp(1rem, 1.5vw, 1.5rem);
  }

  .upnext-title {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.3vw, 1.5rem);
    font-weight: 400;
    color: var(--timber);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .upnext-arrow-wrap {
    position: relative;
    cursor: pointer;
  }

  .upnext-arrow {
    display: block;
    width: clamp(1rem, 1.2vw, 1.25rem);
    height: auto;
  }

  .upnext-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .upnext-body p {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.4;
    margin: 0;
  }

  .upnext-cta {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.4;
    margin: 1rem 0 0;
  }

  /* Section rule */

  .section-rule {
    height: 1px;
    border: none;
    background-color: var(--chalk);
  }

  /* Superfooter */

  .superfooter {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
    padding-block: clamp(2rem, 4vw, 4rem);
  }

  .superfooter-heading {
    font-family: var(--font-sans);
    font-size: clamp(1.375rem, 1.8vw, 1.875rem);
    font-weight: 400;
    color: var(--timber);
    line-height: 1.2;
    margin: 0 0 clamp(0.875rem, 1.3vw, 1.5rem);
  }

  .superfooter-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .superfooter-body p {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.2vw, 1.375rem);
    color: var(--timber);
    line-height: 1.4;
    margin: 0;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: clamp(0.4rem, 0.8vw, 0.65rem);
    padding-block-start: 0.25rem;
  }


  /* Responsive */

  @media (max-width: 900px) {
    .tab-bar {
      flex-wrap: wrap;
      max-width: 100%;
      border-radius: 1.5rem;
      gap: 4px;
    }

    .tab-button {
      flex: 0 0 calc(33.333% - 3px);
    }

    .home-main {
      grid-template-columns: 1fr;
    }

    .tab-panels {
      padding-block-start: 0;
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .home {
      padding-inline: 1.25rem;
    }

    .home-top {
      flex-direction: column;
      gap: 1.5rem;
    }

    .home-nav {
      display: none;
    }

    .tab-bar {
      flex-wrap: wrap;
      max-width: 100%;
      border-radius: 1.25rem;
      gap: 4px;
    }

    .tab-button {
      flex: 0 0 calc(50% - 2px);
      padding: 0.75rem 1rem 0.5rem;
    }


    .lavalamp-pill {
      display: none;
    }

    .home-main {
      gap: 2rem;
    }

    .cards-grid {
      grid-template-columns: 1fr 1fr;
      row-gap: 0.25rem;
    }

    .card {
      min-height: 0;
    }

    .upnext-card {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 1.5rem;
    }

    .superfooter {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-nav {
      display: none;
    }
  }
</style>

<script is:inline>
  document.addEventListener("alpine:init", () => {
    Alpine.data("homeTab", () => ({
      tab: "anyone",
      hoverTab: null,
      panelHeight: 0,
      activeLeft: 0,
      activeWidth: 0,
      activeTop: 0,
      activeHeight: 0,
      lavalampLeft: 0,
      lavalampWidth: 0,
      lavalampTop: 0,
      lavalampHeight: 0,
      lavalampReady: false,

      init() {
        this.$nextTick(() => {
          this.resetLavalamp();
          this.snapActive();
          this.measurePanel();
          setTimeout(() => {
            this.resetLavalamp();
            this.snapActive();
            this.lavalampReady = true;
          }, 100);
        });

        window.addEventListener("resize", () => {
          this.measurePanel();
          this.snapActive();
          this.resetLavalamp();
        });
      },

      measurePanel() {
        const panel = this.$refs.tabPanels?.querySelector(
          "[role='tabpanel']:not([style*='display: none'])",
        );
        if (panel) this.panelHeight = panel.scrollHeight;
      },

      moveLavalamp(el, id) {
        const bar = this.$refs.tabBar.getBoundingClientRect();
        const btn = el.getBoundingClientRect();
        this.lavalampLeft = btn.left - bar.left;
        this.lavalampWidth = btn.width;
        this.lavalampTop = btn.top - bar.top;
        this.lavalampHeight = btn.height;
        if (id) this.hoverTab = id;
      },

      findActive() {
        return this.$refs.tabBar.querySelector("[aria-selected='true']")
          || this.$refs.tabBar.querySelector(".tab-button");
      },

      resetLavalamp() {
        this.hoverTab = null;
        const active = this.findActive();
        if (active) {
          const bar = this.$refs.tabBar.getBoundingClientRect();
          const btn = active.getBoundingClientRect();
          this.lavalampLeft = btn.left - bar.left;
          this.lavalampWidth = btn.width;
          this.lavalampTop = btn.top - bar.top;
          this.lavalampHeight = btn.height;
        }
      },

      snapActive() {
        const active = this.findActive();
        if (active) {
          const bar = this.$refs.tabBar.getBoundingClientRect();
          const btn = active.getBoundingClientRect();
          this.activeLeft = btn.left - bar.left;
          this.activeWidth = btn.width;
          this.activeTop = btn.top - bar.top;
          this.activeHeight = btn.height;
        }
      },

      selectTab(id, el) {
        this.tab = id;
        this.$nextTick(() => {
          this.moveLavalamp(el);
          this.snapActive();
          this.measurePanel();
        });
      },
    }));
  });
</script>
